DOKU_MODE=production
DOKU_CLIENT_ID=replace-with-production-client-id
DOKU_SECRET_KEY=replace-with-production-secret-key
DOKU_MERCHANT_ID=replace-with-production-merchant-id
DOKU_BASE_URL=https://api.doku.com
DOKU_RETURN_URL=https://your-domain.example
DOKU_NOTIFICATION_URL=https://your-domain.example/api/payment/doku/webhook
DOKU_DEFAULT_AMOUNT=25000
DOKU_CURRENCY=IDR
DOKU_SIMULATE_UNTIL_CONFIGURED=true
PAYMENT_FOLLOWUP_SECONDS=60
